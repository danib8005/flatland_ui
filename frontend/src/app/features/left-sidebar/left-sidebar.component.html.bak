<div class="sidebar-content">
  @if (store.session(); as s) {
@if (store.state()) {
<h3 class="section-title">Agents ({{ store.agents().length }})</h3>
      <div class="agent-list">
        @for (a of store.agents(); track a.handle) {
          <div
            class="agent-card"
            [class.selected]="isSelected(a.handle)"
            (click)="toggleSelect(a.handle)">

            <div class="agent-header">
              <span class="agent-dot" [style.background]="agentColor(a.handle)"></span>
              <span class="agent-name">Train {{ a.handle }}</span>
              <span class="agent-state state-{{ a.state.toLowerCase() }}">{{ a.state }}</span>
            </div>

            <div class="agent-meta">
              <span class="cell-type-badge cell-{{ a.cell_type.toLowerCase() }}">
                {{ a.cell_type }}
              </span>
              @if (a.position) {
                <span class="agent-pos">[{{ a.position[0] }}, {{ a.position[1] }}]</span>
              }
            </div>

            @if (a.next_decision; as nd) {
              <div class="agent-actions" (click)="$event.stopPropagation()">
                <span class="actions-label">Next: {{ nd.cell_type }}</span>
                <div class="action-buttons">
                  @for (opt of nd.options; track opt.action) {
                    <button
                      class="action-btn"
                      [class.override]="isOverrideOption(a.handle, opt.action)"
                      (click)="onActionClick(a.handle, opt.action, isOverrideOption(a.handle, opt.action))">
                      {{ opt.label }}
                    </button>
                  }
                </div>
              </div>
            }
          </div>
        }
      </div>

      <h3 class="section-title">Connection</h3>
      <div class="info-row">
        <span class="label">WebSocket</span>
        <span class="value">
          @if (store.wsConnected()) {
            <span class="dot connected"></span> Connected
          } @else {
            <span class="dot disconnected"></span> Offline
          }
        </span>
      </div>
    }
  } @else {
    <div class="empty-state">
      <span class="empty-icon">▦</span>
      <p class="empty-title">Keine aktive Session</p>
      <p class="empty-desc">Klicke <strong>+ New Session</strong> in der Toolbar um zu starten.</p>
    </div>
  }
