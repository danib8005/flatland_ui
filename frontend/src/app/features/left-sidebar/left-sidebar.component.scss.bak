:host {
  display: block;
  height: 100%;
  overflow-y: auto;
}

.sidebar-content {
  padding: 12px 16px;
  font-size: 13px;
}

.section-title {
  font-size: 10px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.8px;
  color: var(--sbb-color-granite, #686868);
  margin: 16px 0 6px;
}
.section-title:first-child { margin-top: 0; }

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 4px 0;
}
.info-row .label { color: var(--sbb-color-granite, #686868); font-size: 12px; }
.info-row .value { color: var(--sbb-color-charcoal, #212121); font-size: 12px; font-weight: 600; }

.progress-row {
  display: flex;
  justify-content: space-between;
  font-size: 12px;
  margin-bottom: 4px;
}
.step-counter { font-weight: 600; font-variant-numeric: tabular-nums; }
.step-pct { color: var(--sbb-color-granite, #686868); }

.progress-bar {
  height: 4px;
  background: var(--sbb-color-cloud, #d2d2d2);
  border-radius: 2px;
  overflow: hidden;
  margin-bottom: 8px;
}
.progress-fill {
  height: 100%;
  background: var(--sbb-color-red, #eb0000);
  transition: width 0.3s;
}

.agent-list {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.agent-card {
  background: var(--sbb-color-milk, #f6f6f6);
  border: 1px solid transparent;
  border-radius: 4px;
  padding: 8px 10px;
  cursor: pointer;
  transition: all 0.15s;
}
.agent-card:hover {
  background: white;
  border-color: var(--sbb-color-cloud, #d2d2d2);
}
.agent-card.selected {
  background: white;
  border-color: var(--sbb-color-orange, #ffaa00);
  box-shadow: 0 0 0 1px var(--sbb-color-orange, #ffaa00);
}

.agent-header {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 4px;
}

.agent-dot {
  width: 12px;
  height: 12px;
  border-radius: 50%;
  border: 2px solid white;
  box-shadow: 0 0 0 1px var(--sbb-color-cloud, #d2d2d2);
}

.agent-name {
  font-size: 13px;
  font-weight: 700;
  color: var(--sbb-color-charcoal, #212121);
  flex: 1;
}

.agent-state {
  font-size: 9px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  padding: 2px 6px;
  border-radius: 3px;
  background: #d2d2d2;
  color: #212121;
}
.agent-state.state-moving { background: #00973b; color: white; }
.agent-state.state-done { background: #0079c7; color: white; }
.agent-state.state-stopped { background: #ffaa00; color: white; }
.agent-state.state-malfunction { background: #ffaa00; color: white; }
.agent-state.state-waiting { background: #d2d2d2; color: #212121; }
.agent-state.state-ready_to_depart { background: #d2d2d2; color: #212121; }

.agent-meta {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 6px;
}

.cell-type-badge {
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 0.5px;
  padding: 2px 6px;
  border-radius: 3px;
  background: #d2d2d2;
  color: #212121;
}
.cell-type-badge.cell-switch { background: #ffaa00; color: white; }
.cell-type-badge.cell-merging { background: #9c4ddc; color: white; }
.cell-type-badge.cell-done { background: #0079c7; color: white; }
.cell-type-badge.cell-forward_only { background: #00973b; color: white; opacity: 0.7; }
.cell-type-badge.cell-outside { background: #d2d2d2; color: #686868; }

.agent-pos {
  font-family: monospace;
  font-size: 10px;
  color: var(--sbb-color-granite, #686868);
}

.agent-actions {
  margin-top: 6px;
  padding-top: 6px;
  border-top: 1px dashed var(--sbb-color-cloud, #d2d2d2);
}

.actions-label {
  font-size: 10px;
  color: var(--sbb-color-granite, #686868);
  text-transform: uppercase;
  letter-spacing: 0.5px;
  font-weight: 600;
  display: block;
  margin-bottom: 4px;
}

.action-buttons {
  display: flex;
  flex-wrap: wrap;
  gap: 4px;
}

.action-btn {
  font-family: inherit;
  font-size: 11px;
  font-weight: 600;
  padding: 4px 10px;
  border-radius: 12px;
  border: 1.5px solid var(--sbb-color-charcoal, #212121);
  background: white;
  color: var(--sbb-color-charcoal, #212121);
  cursor: pointer;
  transition: all 0.15s;
  white-space: nowrap;
}
.action-btn:hover {
  background: var(--sbb-color-charcoal, #212121);
  color: white;
}
.action-btn.override {
  background: var(--sbb-color-red, #eb0000);
  border-color: var(--sbb-color-red, #eb0000);
  color: white;
  box-shadow: 0 1px 4px rgba(235, 0, 0, 0.3);
}
.action-btn.override:hover {
  background: #c00;
}

.dot {
  display: inline-block;
  width: 8px;
  height: 8px;
  border-radius: 50%;
  margin-right: 4px;
}
.dot.connected { background: #00973b; }
.dot.disconnected { background: #686868; }

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding: 48px 16px 24px;
  gap: 12px;
}

.empty-icon {
  font-size: 36px;
  color: var(--sbb-color-cloud, #d2d2d2);
  line-height: 1;
}

.empty-title {
  font-size: 14px;
  font-weight: 600;
  color: var(--sbb-color-charcoal, #212121);
  margin: 0;
}

.empty-desc {
  font-size: 13px;
  color: var(--sbb-color-granite, #686868);
  margin: 0;
  line-height: 1.5;
}
.empty-desc strong {
  color: var(--sbb-color-red, #eb0000);
}
