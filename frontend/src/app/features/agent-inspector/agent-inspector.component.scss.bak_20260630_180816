:host {
  display: contents;
}

.agent-overlay {
  position: absolute;
  left: 12px;
  bottom: 12px;
  z-index: 20;
  width: 280px;
  max-width: calc(100% - 24px);
  background: var(--sbb-color-white, #fff);
  border: 1px solid var(--sbb-color-cloud, #d2d2d2);
  border-radius: 6px;
  box-shadow: 0 6px 20px rgba(0, 0, 0, 0.16);
  padding: 10px 12px;
}

.ao-head {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 8px;
}

.ao-dot {
  width: 12px;
  height: 12px;
  border-radius: 50%;
  flex-shrink: 0;
  border: 1px solid #fff;
  box-shadow: 0 0 0 1px var(--sbb-color-cloud, #d2d2d2);
}

.ao-title {
  font-weight: 600;
  font-size: 14px;
  color: var(--sbb-color-charcoal, #212121);
}

.ao-malf {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 16px;
  height: 16px;
  border-radius: 50%;
  background: var(--sbb-color-red, #eb0000);
  color: #fff;
  font-weight: 700;
  font-size: 11px;
}

.ao-state {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.4px;
  text-transform: uppercase;
  padding: 2px 8px;
  border-radius: 9px;
  background: var(--sbb-color-milk, #f6f6f6);
  color: var(--sbb-color-charcoal, #212121);
}
.state-MOVING { background: #00973b; color: #fff; }
.state-WAITING, .state-READY_TO_DEPART { background: var(--sbb-color-orange, #ffaa00); color: var(--sbb-color-charcoal, #212121); }
.state-MALFUNCTION, .state-MALFUNCTION_OFF_MAP { background: var(--sbb-color-red, #eb0000); color: #fff; }
.state-DONE { background: var(--sbb-color-cloud, #d2d2d2); color: var(--sbb-color-charcoal, #212121); }

.ao-close {
  margin-left: auto;
  border: 0;
  background: transparent;
  color: var(--sbb-color-granite, #686868);
  font-size: 20px;
  line-height: 1;
  cursor: pointer;
  padding: 0 2px;
}
.ao-close:hover { color: var(--sbb-color-charcoal, #212121); }

.ao-malf-banner {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 6px 8px;
  margin-bottom: 8px;
  border-radius: 4px;
  background: color-mix(in srgb, var(--sbb-color-red, #eb0000) 10%, white);
  border-left: 3px solid var(--sbb-color-red, #eb0000);
}

.ao-malf-ico {
  flex-shrink: 0;
  width: 16px;
  height: 16px;
  border-radius: 50%;
  background: var(--sbb-color-red, #eb0000);
  color: #fff;
  font-weight: 700;
  font-size: 11px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.ao-malf-text {
  font-size: 12px;
  color: var(--sbb-color-charcoal, #212121);
  font-variant-numeric: tabular-nums;
}
.ao-malf-text strong { color: var(--sbb-color-red, #eb0000); }
.ao-malf-at { color: var(--sbb-color-granite, #686868); }

.ao-facts {
  display: flex;
  flex-wrap: wrap;
  gap: 6px 10px;
  font-size: 12px;
  color: var(--sbb-color-iron, #444);
  font-variant-numeric: tabular-nums;
  margin-bottom: 8px;
}
.ao-fact.warn { color: var(--sbb-color-orange, #cc8800); font-weight: 600; }
.ao-fact.ok { color: #00973b; }

.ao-actions {
  border-top: 1px solid var(--sbb-color-cloud, #d2d2d2);
  padding-top: 8px;
}

.ao-actions-label {
  display: block;
  font-size: 10px;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  color: var(--sbb-color-granite, #686868);
  font-weight: 600;
  margin-bottom: 6px;
}

.ao-buttons {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
}

.ao-btn {
  border: 1px solid var(--sbb-color-cloud, #d2d2d2);
  background: var(--sbb-color-white, #fff);
  color: var(--sbb-color-charcoal, #212121);
  border-radius: 3px;
  padding: 5px 12px;
  font: inherit;
  font-size: 12px;
  cursor: pointer;
}
.ao-btn:hover {
  border-color: var(--sbb-color-charcoal, #212121);
}
.ao-btn.override {
  background: var(--sbb-color-charcoal, #212121);
  border-color: var(--sbb-color-charcoal, #212121);
  color: #fff;
}
